{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DirtOS",
  "version": "0.1.0",
  "identifier": "com.dirtos.app",
  "build": {
    "beforeDevCommand": "bash -c 'source ~/.nvm/nvm.sh && nvm use 22 && pnpm vite:dev'",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DirtOS",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
