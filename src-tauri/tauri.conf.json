{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DirtOS",
  "version": "0.6.4",
  "identifier": "com.dirtos.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DirtOS",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../assets/logo-dark.png",
      "../assets/logo-light.png",
      "../assets/splash.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows-installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
