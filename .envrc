# Source environment-specific aliases
if [ -f ".aliases.env" ]; then
    source ".aliases.env"
else
    source "${HOME}/.aliases.dev"
fi

# Set NVM
if [ -f ".nvmrc" ]; then
    NODE_VERSION=$(<.nvmrc)
    export NODE_VERSION
    source /home/native/.nvm/nvm.sh
    nvm use "$NODE_VERSION"
fi

# Set Forgejo key
export GIT_ACCESS_KEY=33a84942658c3fd39921ce5e93f5e8dce1d78362
